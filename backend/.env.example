# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret
JWT_SECRET=your-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRE=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=10
SHOW_OTP_IN_CONSOLE=false
TWOFACTOR_API_KEY=your_2factor_api_key_here
TWOFACTOR_BASE_URL=https://2factor.in/API/V1
TWOFACTOR_COUNTRY_CODE=91

# Uploads
MAX_FILE_SIZE=5242880
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin seed account
ADMIN_SEED_EMAIL=admin@snapfix.com
ADMIN_SEED_PASSWORD=Admin12345
ADMIN_SEED_NAME=Super Admin
